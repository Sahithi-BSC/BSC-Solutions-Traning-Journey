{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: dev server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app"],
      "justMyCode": true
    },
    {
      "name": "Python: Tests",
      "type": "python",
